[Panel]
IPPure = script-name=IPPure, update-interval=43200

[Script]
IPPure = type=generic, timeout=10, script-path=https://raw.githubusercontent.com/IBL3ND/module/main/IP_Clean.JS, argument=title=IPPure&icon=shield.lefthalf.filled