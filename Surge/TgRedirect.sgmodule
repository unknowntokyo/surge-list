#!name=Telegram 链接重定向
#!desc=选择要跳转到的 Telegram 客户端。
#!arguments=CLIENT:Turrit
#!arguments-desc=跳转选项：Telegram, Swiftgram, Turrit, iMe, Nicegram, Lingogram。

[MITM]
hostname = %APPEND% t.me

[Script]
# Telegram 链接重定向脚本
Telegram重定向 = type=http-request,pattern=^https?://t\.me/.+,requires-body=0,max-size=0,script-path=https://raw.githubusercontent.com/IBL3ND/module/refs/heads/main/TgRedirect.js,argument=CLIENT=Turrit,timeout=10